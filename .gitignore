# Agentica v2 — .gitignore

# ── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/
*.egg-info/

# ── Environment ───────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/mcp.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Agentica runtime files ────────────────────────────────────────────────────
# Commit decisions.json + patterns.json — they are shared team knowledge
# Exclude only large runtime-generated files
memory/trajectories/
memory/*.log

# Generated workspace files (user-specific)
*.code-workspace

# ── Test & coverage outputs ───────────────────────────────────────────────────
coverage/
test-results/

# ── Build ─────────────────────────────────────────────────────────────────────
dist/
build/
